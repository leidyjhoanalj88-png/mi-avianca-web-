<style>
  :root {
    --nequi: #7B2FBE;
    --nequi2: #A855F7;
    --pink: #EC4899;
    --dark: #0A0A0F;
    --card: #111118;
    --border: rgba(168,85,247,0.2);
    --text: #F1F0F7;
    --muted: #9990B8;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--dark);
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    overflow-x: hidden;
  }

  /* BG */
  body::before {
    content: '';
    position: fixed;
    top: -200px; left: 50%;
    transform: translateX(-50%);
    width: 800px; height: 800px;
    background: radial-gradient(circle, rgba(123,47,190,0.15) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  /* NAV */
  nav {
    position: sticky; top: 0;
    z-index: 100;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 18px 24px;
    background: rgba(10,10,15,0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .logo {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 1.2rem;
    background: linear-gradient(135deg, var(--nequi2), var(--pink));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .nav-btn {
    background: linear-gradient(135deg, var(--nequi), var(--pink));
    color: #fff;
    border: none;
    padding: 10px 20px;
    border-radius: 50px;
    font-family: 'DM Sans', sans-serif;
    font-weight: 500;
    font-size: 0.85rem;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    transition: opacity 0.2s, transform 0.2s;
  }
  .nav-btn:hover { opacity: 0.85; transform: scale(1.03); }

  /* HERO */
  .hero {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 80px 24px 60px;
  }

  .badge {
    display: inline-block;
    background: rgba(168,85,247,0.15);
    border: 1px solid var(--border);
    color: var(--nequi2);
    font-size: 0.78rem;
    font-weight: 500;
    padding: 6px 16px;
    border-radius: 50px;
    margin-bottom: 24px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .hero h1 {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: clamp(2.2rem, 8vw, 4rem);
    line-height: 1.1;
    margin-bottom: 20px;
  }

  .hero h1 span {
    background: linear-gradient(135deg, var(--nequi2), var(--pink));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero p {
    color: var(--muted);
    font-size: 1.05rem;
    max-width: 480px;
    margin: 0 auto 36px;
    line-height: 1.6;
  }

  .hero-btns {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-primary {
    background: linear-gradient(135deg, var(--nequi), var(--pink));
    color: #fff;
    border: none;
    padding: 14px 28px;
    border-radius: 50px;
    font-family: 'DM Sans', sans-serif;
    font-weight: 500;
    font-size: 0.95rem;
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 4px 24px rgba(123,47,190,0.4);
  }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 32px rgba(123,47,190,0.5); }

  .btn-outline {
    background: transparent;
    color: var(--text);
    border: 1px solid var(--border);
    padding: 14px 28px;
    border-radius: 50px;
    font-family: 'DM Sans', sans-serif;
    font-weight: 500;
    font-size: 0.95rem;
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: border-color 0.2s, background 0.2s;
  }
  .btn-outline:hover { border-color: var(--nequi2); background: rgba(168,85,247,0.08); }

  /* STATS */
  .stats {
    position: relative; z-index: 1;
    display: flex;
    justify-content: center;
    gap: 40px;
    flex-wrap: wrap;
    padding: 0 24px 70px;
  }

  .stat {
    text-align: center;
  }

  .stat-num {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 2rem;
    background: linear-gradient(135deg, var(--nequi2), var(--pink));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .stat-label { color: var(--muted); font-size: 0.85rem; margin-top: 4px; }

  /* SECTION */
  section {
    position: relative; z-index: 1;
    padding: 60px 24px;
    max-width: 900px;
    margin: 0 auto;
  }

  .section-title {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 1.6rem;
    margin-bottom: 8px;
  }

  .section-sub {
    color: var(--muted);
    font-size: 0.95rem;
    margin-bottom: 36px;
  }

  /* CARDS */
  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 16px;
  }

  .card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 28px 24px;
    transition: border-color 0.2s, transform 0.2s;
    position: relative;
    overflow: hidden;
  }

  .card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--nequi), var(--pink));
    opacity: 0;
    transition: opacity 0.3s;
  }

  .card:hover { border-color: rgba(168,85,247,0.5); transform: translateY(-4px); }
  .card:hover::before { opacity: 1; }

  .card-icon {
    font-size: 2rem;
    margin-bottom: 16px;
    display: block;
  }

  .card h3 {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 1.1rem;
    margin-bottom: 10px;
  }

  .card p {
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.6;
    margin-bottom: 20px;
  }

  .card-tag {
    display: inline-block;
    background: rgba(168,85,247,0.1);
    border: 1px solid rgba(168,85,247,0.25);
    color: var(--nequi2);
    font-size: 0.75rem;
    padding: 4px 12px;
    border-radius: 50px;
    margin-right: 6px;
    margin-bottom: 6px;
  }

  /* PRECIOS */
  .pricing {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 16px;
    margin-top: 36px;
  }

  .price-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 32px 24px;
    text-align: center;
    transition: transform 0.2s;
  }

  .price-card.featured {
    border-color: var(--nequi2);
    background: linear-gradient(145deg, rgba(123,47,190,0.15), rgba(236,72,153,0.08));
    position: relative;
  }

  .price-card.featured::after {
    content: '⭐ Popular';
    position: absolute;
    top: -12px; left: 50%;
    transform: translateX(-50%);
    background: linear-gradient(135deg, var(--nequi), var(--pink));
    color: #fff;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 4px 16px;
    border-radius: 50px;
    white-space: nowrap;
  }

  .price-card:hover { transform: translateY(-4px); }

  .price-name {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 16px;
  }

  .price-amount {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 2.4rem;
    margin-bottom: 4px;
  }

  .price-amount span {
    font-size: 1rem;
    color: var(--muted);
    font-weight: 400;
  }

  .price-period {
    color: var(--muted);
    font-size: 0.85rem;
    margin-bottom: 24px;
  }

  .price-features {
    list-style: none;
    text-align: left;
    margin-bottom: 28px;
  }

  .price-features li {
    color: var(--muted);
    font-size: 0.9rem;
    padding: 6px 0;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .price-features li::before {
    content: '✓';
    color: var(--nequi2);
    font-weight: 700;
    flex-shrink: 0;
  }

  /* APK SECTION */
  .apk-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 16px;
  }

  .apk-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    transition: transform 0.2s, border-color 0.2s;
  }

  .apk-card:hover { transform: translateY(-4px); border-color: rgba(168,85,247,0.5); }

  .apk-header {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .apk-icon {
    width: 56px; height: 56px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.8rem;
    flex-shrink: 0;
  }

  .apk-icon.android { background: rgba(61,220,132,0.15); }
  .apk-icon.ios { background: rgba(168,85,247,0.15); }

  .apk-name {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 1.1rem;
  }

  .apk-os { color: var(--muted); font-size: 0.85rem; }

  .apk-features {
    list-style: none;
  }

  .apk-features li {
    color: var(--muted);
    font-size: 0.88rem;
    padding: 5px 0;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .apk-features li::before {
    content: '→';
    color: var(--nequi2);
  }

  /* SALDO TABLE */
  .saldo-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 20px;
  }

  .saldo-table th {
    font-family: 'Syne', sans-serif;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--muted);
    padding: 12px 16px;
    text-align: left;
    border-bottom: 1px solid var(--border);
  }

  .saldo-table td {
    padding: 14px 16px;
    font-size: 0.95rem;
    border-bottom: 1px solid rgba(168,85,247,0.08);
  }

  .saldo-table tr:hover td { background: rgba(168,85,247,0.05); }

  .saldo-table .price-col {
    color: var(--nequi2);
    font-weight: 600;
    font-family: 'Syne', sans-serif;
  }

  .saldo-table .saldo-col {
    color: var(--pink);
    font-weight: 600;
  }

  /* CONTACT */
  .contact-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 16px;
    margin-top: 36px;
  }

  .contact-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 24px;
    text-align: center;
    text-decoration: none;
    color: var(--text);
    transition: transform 0.2s, border-color 0.2s;
    display: block;
  }

  .contact-card:hover { transform: translateY(-3px); border-color: rgba(168,85,247,0.5); }

  .contact-card .icon { font-size: 2rem; margin-bottom: 12px; display: block; }
  .contact-card .name { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 1rem; margin-bottom: 4px; }
  .contact-card .role { color: var(--muted); font-size: 0.82rem; }

  /* DIVIDER */
  .divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border), transparent);
    margin: 0 24px;
  }

  /* FOOTER */
  footer {
    position: relative; z-index: 1;
    text-align: center;
    padding: 40px 24px;
    color: var(--muted);
    font-size: 0.85rem;
  }

  footer a { color: var(--nequi2); text-decoration: none; }

  /* ANIMATIONS */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .hero > * { animation: fadeUp 0.6s ease both; }
  .hero .badge { animation-delay: 0.1s; }
  .hero h1 { animation-delay: 0.2s; }
  .hero p { animation-delay: 0.3s; }
  .hero-btns { animation-delay: 0.4s; }
  .stats { animation: fadeUp 0.6s 0.5s ease both; }
</style>
